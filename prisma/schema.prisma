generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// NextAuth models

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// App models

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime? @map("email_verified")
  baseCurrency  String    @default("USD") @map("base_currency")
  locale        String    @default("en")
  timezone      String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts         Account[]
  sessions         Session[]
  expenses         Expense[]
  categories       Category[]
  telegramChatId   String?            @unique @map("telegram_chat_id")
  telegramMessages TelegramMessage[]
  telegramLinkTokens TelegramLinkToken[]
  cliAuthRequests  CliAuthRequest[]
  cliTokens        CliToken[]

  @@map("users")
}

model Category {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  color     String
  icon      String?
  createdAt DateTime @default(now()) @map("created_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses Expense[]

  @@unique([userId, name])
  @@index([userId])
  @@map("categories")
}

model Expense {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  amount       Decimal  @db.Decimal(12, 2)
  currency     String
  baseAmount   Decimal  @db.Decimal(12, 2) @map("base_amount")
  exchangeRate Decimal  @db.Decimal(12, 6) @map("exchange_rate")
  description  String
  categoryId   String   @map("category_id")
  date         DateTime @db.Date
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id])

  @@index([userId, date])
  @@index([userId, categoryId])
  @@map("expenses")
}

model TelegramMessage {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  role       String
  content    String?
  toolCalls  Json?    @map("tool_calls")
  toolCallId String?  @map("tool_call_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("telegram_messages")
}

model TelegramLinkToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @unique @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("telegram_link_tokens")
}

model CliAuthRequest {
  id         String   @id @default(cuid())
  code       String   @unique
  userCode   String   @unique @map("user_code")
  status     String
  userId     String?  @map("user_id")
  expiresAt  DateTime @map("expires_at")
  approvedAt DateTime? @map("approved_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, expiresAt])
  @@index([userId, createdAt])
  @@map("cli_auth_requests")
}

model CliToken {
  id         String    @id @default(cuid())
  userId     String    @map("user_id")
  name       String?
  tokenHash  String    @unique @map("token_hash")
  lastUsedAt DateTime? @map("last_used_at")
  expiresAt  DateTime? @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, revokedAt])
  @@map("cli_tokens")
}
