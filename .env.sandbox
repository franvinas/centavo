# Local development sandbox. Safe to commit: no real credentials.

# Database
DATABASE_URL="postgresql://centavo:centavo@localhost:5432/centavo"

# Auth
AUTH_SECRET="local-sandbox-auth-secret-change-if-needed"
NEXTAUTH_SECRET="local-sandbox-auth-secret-change-if-needed"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth is optional in the sandbox. Email OTP works through Mailpit.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Local email OTP via Mailpit
EMAIL_TRANSPORT="smtp"
EMAIL_SERVER_HOST="localhost"
EMAIL_SERVER_PORT="1026"
EMAIL_FROM="Centavo <noreply@localhost>"

# Optional external integrations. Fill these only when testing related flows.
RESEND_API_KEY=""
OPEN_EXCHANGE_RATES_APP_ID=""
OPENAI_API_KEY=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET="local-telegram-webhook-secret"
TELEGRAM_WEBHOOK_URL="http://localhost:3000/api/telegram/webhook"
TELEGRAM_BOT_USERNAME="CentaBot"
